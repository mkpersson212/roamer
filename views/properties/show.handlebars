<div>
  <h2>{{property.title}}</h2>
  <p>{{property.cityLocation}}</p>
  <p><strong>{{formatCents property.nightlyRate}}</strong> / night</p>
  <p>Hosted by <strong>{{property.firstName}} {{property.lastName}}</strong></p>

  <hr>

  <h5>Amenities</h5>
  {{#if amenities.length}}
    <ul>
      {{#each amenities}}
        <li>{{this.amenityName}}</li>
      {{/each}}
    </ul>
  {{else}}
    <p>No amenities listed for this property.</p>
  {{/if}}

  <hr>

  <h5>Availability</h5>
  {{#if availability.length}}
    <ul>
      {{#each availability}}
        <li>
          <span>
            {{dateStr this.startDate}} &ndash; {{dateStr this.endDate}}
            {{#if this.isAvailable}}
              <span>Available</span>
            {{else}}
              <span>Unavailable</span>
            {{/if}}
          </span>
          {{#if (eq ../currentUser.userId ../property.hostId)}}
            <form action="/property_availability/remove" method="POST">
              <input type="hidden" name="_csrf" value="{{../_csrfToken}}">
              <input type="hidden" name="availabilityId" value="{{this.availabilityId}}">
              <input type="hidden" name="propertyId" value="{{../property.propertyId}}">
              <button type="submit">Remove</button>
            </form>
          {{/if}}
        </li>
      {{/each}}
    </ul>
  {{else}}
    <p>No availability windows set.</p>
  {{/if}}

  {{#if (eq currentUser.userId property.hostId)}}
    <h6>Add Availability Window</h6>
    <form action="/property_availability/add" method="POST">
      <input type="hidden" name="_csrf" value="{{_csrfToken}}">
      <input type="hidden" name="propertyId" value="{{property.propertyId}}">
      <div>
        <label>Start Date</label>
        <input type="date" name="startDate" required>
      </div>
      <div>
        <label>End Date</label>
        <input type="date" name="endDate" required>
      </div>
      <div>
        <input type="checkbox" name="isAvailable" id="isAvailable" checked>
        <label for="isAvailable">Available</label>
      </div>
      <div>
        <button type="submit">Add</button>
      </div>
    </form>
  {{/if}}
</div>

<div>
  {{#if currentUser}}
    {{#if (eq currentUser.userId property.hostId)}}
      <div>
        <h6>Manage this property</h6>
        <a href="/properties/form?id={{property.propertyId}}">Edit Property</a>
      </div>
    {{/if}}
  {{/if}}
</div>

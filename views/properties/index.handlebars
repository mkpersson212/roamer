<div class="d-flex justify-content-between align-items-center mb-4">
  <h2>Properties</h2>
  {{#if currentUser}}
    <a href="/properties/form" class="btn btn-primary btn-sm">+ List a Property</a>
  {{/if}}
</div>

{{#if properties.length}}
  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    {{#each properties}}
      <div class="col">
        <div class="card h-100">
          <div class="card-body">
            <h5 class="card-title">{{this.title}}</h5>
            <p class="card-text text-muted">{{this.cityLocation}}</p>
            <p class="card-text">
              <strong>{{formatCents this.nightlyRate}}</strong> / night
            </p>
            <p class="card-text">
              <small class="text-muted">Hosted by {{this.firstName}} {{this.lastName}}</small>
            </p>
          </div>
          <div class="card-footer">
            <a href="/properties/show/{{this.propertyId}}" class="btn btn-outline-primary btn-sm">View</a>
          </div>
        </div>
      </div>
    {{/each}}
  </div>
{{else}}
  <p class="text-muted">No properties listed yet.</p>
{{/if}}

<div>
  <h2>{{#if property}}Edit{{else}}New{{/if}} Property</h2>
  <form action="/properties/upsert" method="POST">
    <input type="hidden" name="_csrf" value="{{_csrfToken}}">
    {{#if property}}
      <input type="hidden" name="propertyId" value="{{property.propertyId}}">
    {{/if}}

    <div>
      <label for="title">Title</label>
      <input type="text" id="title" name="title"
             value="{{property.title}}" required>
    </div>

    <div>
      <label for="cityLocation">City / Location</label>
      <input type="text" id="cityLocation" name="cityLocation"
             value="{{property.cityLocation}}" required>
    </div>

    <div>
      <label for="nightlyRate">Nightly Rate ($)</label>
      <input type="number" id="nightlyRate" name="nightlyRate"
             value="{{#if property}}{{divide property.nightlyRate 100}}{{/if}}"
             step="0.01" min="0" required>
    </div>

    <div>
      <label>Amenities</label>
      <div>
        {{#each amenities}}
          <div>
            <input type="checkbox"
                   name="amenityIds" value="{{this.amenityId}}" id="amenity-{{this.amenityId}}"
                   {{#if (someId ../selectedAmenityIds this.amenityId)}}checked{{/if}}>
            <label for="amenity-{{this.amenityId}}">{{this.amenityName}}</label>
          </div>
        {{/each}}
      </div>
    </div>

    <button type="submit">Save Property</button>
    <a href="/properties">Cancel</a>
  </form>
</div>

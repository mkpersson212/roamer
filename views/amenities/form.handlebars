<div class="row justify-content-center">
  <div class="col-md-6">
    <h2 class="mb-4">{{#if amenity}}Edit{{else}}New{{/if}} Amenity</h2>
    <form action="/amenities/upsert" method="POST">
      <input type="hidden" name="_csrf" value="{{_csrfToken}}">
      {{#if amenity}}
        <input type="hidden" name="amenityId" value="{{amenity.amenityId}}">
      {{/if}}

      <div class="mb-3">
        <label for="amenityName" class="form-label">Amenity Name</label>
        <input type="text" class="form-control" id="amenityName" name="amenityName"
               value="{{amenity.amenityName}}" required>
      </div>

      <button type="submit" class="btn btn-primary">Save</button>
      <a href="/amenities" class="btn btn-link">Cancel</a>
    </form>
  </div>
</div>

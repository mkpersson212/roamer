<div>
  <h2>{{#if amenity}}Edit{{else}}New{{/if}} Amenity</h2>
  <form action="/amenities/upsert" method="POST">
    <input type="hidden" name="_csrf" value="{{_csrfToken}}">
    {{#if amenity}}
      <input type="hidden" name="amenityId" value="{{amenity.amenityId}}">
    {{/if}}

    <div>
      <label for="amenityName">Amenity Name</label>
      <input type="text" id="amenityName" name="amenityName"
             value="{{amenity.amenityName}}" required>
    </div>

    <button type="submit">Save</button>
    <a href="/amenities">Cancel</a>
  </form>
</div>
